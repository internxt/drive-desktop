<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  IgnorableNamespaces="com desktop4 desktop5 rescap uap uap10">

  <!--
    Publisher must exactly match the subject of the certificate used to sign
    the generated sparse package. Version is generated from package.json.
  -->
  <Identity
    Name="com.internxt.drive.contextmenu"
    Publisher="__PUBLISHER__"
    Version="__VERSION__"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Internxt Drive Context Menu</DisplayName>
    <PublisherDisplayName>Internxt</PublisherDisplayName>
    <Description>Internxt Drive File Explorer command</Description>
    <Logo>Assets\StoreLogo.png</Logo>

    <!-- The host executable and COM DLL remain in the isolated context-menu
         directory inside the existing NSIS installation. -->
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <!-- Windows 11 is required for placement in the primary context menu. -->
  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="10.0.22000.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <!-- This minimal host exists only to provide the sparse package identity.
         Explorer executes the COM DLL for context-menu commands. -->
    <Application
      Id="InternxtDrive"
      Executable="internxt_context_menu_host.exe"
      uap10:RuntimeBehavior="win32App"
      uap10:TrustLevel="mediumIL">

      <!-- Required package identity metadata. These assets will be added when
           package generation is implemented. -->
      <uap:VisualElements
        AppListEntry="none"
        DisplayName="Internxt Drive"
        Description="Internxt Drive"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />

      <Extensions>
        <!-- Register the compiled DLL as a COM server hosted by Windows. -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Internxt Drive Context Menu">
              <com:Class
                Id="F47A034D-852C-4F60-B721-C31C854183F2"
                Path="internxt_context_menu.dll"
                ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>

        <!-- Add the same IExplorerCommand to files and folders. -->
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type="*">
              <desktop5:Verb
                Id="InternxtCopyShareLink"
                Clsid="F47A034D-852C-4F60-B721-C31C854183F2" />
            </desktop5:ItemType>
            <desktop5:ItemType Type="Directory">
              <desktop5:Verb
                Id="InternxtCopyShareLink"
                Clsid="F47A034D-852C-4F60-B721-C31C854183F2" />
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <rescap:Capability Name="unvirtualizedResources" />
  </Capabilities>
</Package>
